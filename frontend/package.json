{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:staging": "vite build --mode staging",
		"cycles:staging": "powershell -ExecutionPolicy Bypass -File ./scripts/check-staging-cycles.ps1",
		"preview": "vite preview",
		"deploy:staging": "npm run build:staging && node ./scripts/deploy-staging-assets.cjs",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@icp-sdk/canisters": "^3.5.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@dfinity/vetkeys": "^0.4.0",
		"@icp-sdk/auth": "^5.0.0",
		"@icp-sdk/core": "^5.2.0",
		"pdfjs-dist": "^5.4.149",
		"tesseract.js": "^7.0.0"
	}
}
